{
  "name": "truecalling-mcp-server",
  "version": "0.2.0",
  "description": "MCP server exposing TrueCalling operations (candidates, JDs, scoring, enrichment, Emily, WhatsApp, psy, reports) to Claude Code via stdio.",
  "type": "module",
  "bin": {
    "truecalling-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "prepare": "npm run build",
    "dev": "node --env-file-if-exists=.env --import tsx src/index.ts",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "npm run build && node --import tsx --test --test-force-exit test/*.test.ts",
    "inspect": "npm run build && npx @modelcontextprotocol/inspector node --env-file-if-exists=.env dist/index.js",
    "mcp:inspect": "npm run inspect"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@supabase/auth-js": "^2.108.0",
    "@supabase/supabase-js": "^2.45.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Truecalling-ai/truecalling-mcp.git"
  }
}
