# As of v0.2, credentials are NOT stored in .env.
# On first use, Claude Code will ask for your TrueCalling email + password and
# call the `tc_login` tool. The session is then cached at:
#   macOS:   ~/Library/Application Support/truecalling-mcp/session.json
#   Linux:   $XDG_STATE_HOME/truecalling-mcp/session.json
#   Windows: %LOCALAPPDATA%\truecalling-mcp\session.json
# File mode 0600. Refresh token auto-rotates — you should not need to log in again.

# Optional: override Supabase project (defaults are baked into config.ts).
# SUPABASE_URL=https://gxnriabesrpbgpireubf.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# Optional: set to "true" to disable all write/destructive tools.
TC_MCP_READONLY=false
